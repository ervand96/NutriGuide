# NutriGuide environment variables

# Site
NEXT_PUBLIC_SITE_URL=https://nutri-guide-indol.vercel.app

# Affiliate (iHerb Rewards + MyProtein referrals)
# Use your real Rewards code from iHerb account → Rewards → Share
IHERB_RCODE=QXH0410
# Optional: regional storefront so Armenia traffic hits am.iherb.com directly
# IHERB_HOST=am.iherb.com
MY_PROTEIN_RCODE=ERVAND-R5

# Content agent — Cursor SDK (Composer)
# Get key: https://cursor.com/dashboard/integrations → User API Keys
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

# Click & lead analytics (Vercel KV / Upstash — add in Vercel Integrations)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Pinterest automation (optional)
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=
PINTEREST_BOARD=NutriGuide
PINTEREST_DRY_RUN=true
